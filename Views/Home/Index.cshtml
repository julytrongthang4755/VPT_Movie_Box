<script src="~/js/jquery-1.9.1.min.js"></script>
<script src="~/js/easyResponsiveTabs.js"></script>
		<script>
			$(document).ready(function () {
				// Toggle Dropdown
				$("#userDropdown").on("click", function (e) {
					$("#myDropdown").toggleClass("show");
					e.stopPropagation();
				});

				// Click ra ngoài thì đóng dropdown
				$(document).on("click", function (e) {
					if (!$(e.target).closest('#login_section').length) {
						$("#myDropdown").removeClass("show");
					}
				});
			});

			function openProfileModal() {
				$("#profileModal").fadeIn(300);
				$("#myDropdown").removeClass("show");
			}

			function closeProfileModal() {
				$("#profileModal").fadeOut(300);
			}

			// Đóng modal khi nhấn ra ngoài vùng trắng
			window.onclick = function(event) {
				let modal = document.getElementById("profileModal");
				if (event.target == modal) {
					closeProfileModal();
				}
			}

			function changePassword() {
				const oldPw = $("#old-pass").val();
				const newPw = $("#new-pass").val();
    
				// Lấy Token để gửi lên server (tránh lỗi 400)
				const token = $('input[name="__RequestVerificationToken"]').val();

				if (!oldPw || !newPw) {
					alert("Vui lòng nhập đầy đủ mật khẩu cũ và mới!");
					return;
				}

				// Gửi yêu cầu AJAX lên Controller
				$.ajax({
					url: '/Home/ChangePassword',
					type: 'POST',
					data: {
						__RequestVerificationToken: token, 
						oldPassword: oldPw,
						newPassword: newPw
					},
					success: function (res) {
						if (res.success) {
							alert(res.message);
							closeProfileModal();
							// Xóa trắng ô nhập sau khi thành công
							$("#old-pass").val("");
							$("#new-pass").val("");
						} else {
							// Hiển thị lỗi từ Backend (ví dụ: mật khẩu cũ sai)
							alert(res.message);
						}
					},
					error: function () {
						alert("Có lỗi xảy ra khi kết nối với máy chủ.");
					}
				});
			}
		</script>
	<script type="text/javascript">
		$(document).ready(function () {
			//Horizontal Tab
			$('#parentHorizontalTab').easyResponsiveTabs({
				type: 'default', //Types: default, vertical, accordion
				width: 'auto', //auto or any width like 600px
				fit: true, // 100% fit in a container
				tabidentify: 'hor_1', // The tab groups identifier
				activate: function (event) { // Callback function if tab is switched
					var $tab = $(this);
					var $info = $('#nested-tabInfo');
					var $name = $('span', $info);
					$name.text($tab.text());
					$info.show();
				}
			});
		});
	</script>
