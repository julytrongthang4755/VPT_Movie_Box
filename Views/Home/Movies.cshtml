@model List<VPT_Movie_Box.Models.Movie>
<!doctype cshtml>
<cshtml lang="zxx">

<head>
	<!-- Required meta tags -->
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
	<title>Movies</title>
	<link rel="stylesheet" href="~/css/style-starter.css">
	<link href="//fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,600;0,700;1,600&display=swap"
		rel="stylesheet">
	<link rel="stylesheet" type="text/css" href="~/css/user-profile.css">
</head>

<body>
	<!-- header -->
	<header id="site-header" class="w3l-header fixed-top">
		<!--/nav-->
		<nav class="navbar navbar-expand-lg navbar-light fill px-lg-0 py-0 px-3">
			<div class="container">
					<h1>
						<a class="navbar-brand" asp-controller="Home" asp-action="Index">
							<img src="@(Url.Content("~/images/favicon.ico"))" alt="StarBugCinema logo"
								 style="width:24px; height:24px; vertical-align:middle; margin-right:8px;" />
							StarBugCinema
						</a>
					</h1>
			
				<button class="navbar-toggler collapsed" type="button" data-toggle="collapse"
					data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false"
					aria-label="Toggle navigation">
					<!-- <span class="navbar-toggler-icon"></span> -->
					<span class="fa icon-expand fa-bars"></span>
					<span class="fa icon-close fa-times"></span>
				</button>

				<div class="collapse navbar-collapse" id="navbarSupportedContent">
					<ul class="navbar-nav ml-auto">
						<li class="nav-item">
							<a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
						</li>

						<li class="nav-item active">
							<a class="nav-link" asp-controller="Home" asp-action="Movies">Movies</a>
						</li>

						<li class="nav-item">
							<a class="nav-link" asp-controller="Home" asp-action="About">About</a>
						</li>

						<li class="nav-item">
							<a class="nav-link" asp-controller="Home" asp-action="Contact_Us">Contact</a>
						</li>
						<li class="nav-item active">
							<a class="nav-link" asp-controller="Home" asp-action="BookingHistory">History</a>
						</li>
					</ul>

					<!--/search-right-->
					<!--/search-right-->
					<div class="search-right">
						<a href="#search" class="btn search-hny mr-lg-3 mt-lg-0 mt-4" title="search">Search <span
								class="fa fa-search ml-3" aria-hidden="true"></span></a>
						<!-- search popup -->
						<div id="search" class="pop-overlay">
							<div class="popup">
								<form action="#" method="post" class="search-box">
									<input type="search" placeholder="Search your Keyword" name="search"
										required="required" autofocus="">
									<button type="submit" class="btn"><span class="fa fa-search"
											aria-hidden="true"></span></button>
								</form>
								<div class="browse-items">
									<h3 class="hny-title two mt-md-5 mt-4">Browse all:</h3>

									<ul class="search-items">
										<li><a asp-controller="Home" asp-action="Movies">Action</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Drama</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Family</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Thriller</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Comedy</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Romantic</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Tv-Series</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Horror</a></li>

										<li><a asp-controller="Home" asp-action="Movies">Action</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Drama</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Family</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Thriller</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Comedy</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Romantic</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Tv-Series</a></li>
										<li><a asp-controller="Home" asp-action="Movies">Horror</a></li>
									</ul>
								</div>
							</div>
							<a class="close" href="#close">×</a>
						</div>
						<!-- /search popup -->
						<!--/search-right-->
					</div>

					<div class="Login_SignUp" id="login_section" style="font-size: 2rem; display: inline-block; position: relative; margin-left: 15px;">
						@if (User.Identity.IsAuthenticated)
						{
							<a class="nav-link" href="javascript:void(0)" id="userDropdown" style="padding: 0;">
								<i class="fa fa-user-circle-o"></i>
							</a>
        
							<div class="user-dropdown-content" id="myDropdown">
								<div class="dropdown-header">Xin chào, <b>@User.Identity.Name</b></div>
								<hr style="margin: 5px 0;" />
								<a href="javascript:void(0)" onclick="openProfileModal()">
									<i class="fa fa-user-o"></i> Thông tin cá nhân
								</a>
								<form asp-controller="Home" asp-action="Logout" method="post" id="logoutForm" style="display: block;">
									@Html.AntiForgeryToken()
									<button type="submit" class="btn-logout">
										<i class="fa fa-sign-out"></i> Đăng xuất
									</button>
								</form>
							</div>
						}
						else
						{
							<a class="nav-link" asp-controller="Home" asp-action="Sign_In" title="Login">
								<i class="fa fa-user-circle-o"></i>
							</a>
						}
					</div>
					<div id="profileModal" class="modal-custom">
						<div class="modal-content-custom">
							<span class="close-modal" onclick="closeProfileModal()">&times;</span>
							<h2 style="color: #df0e62; margin-bottom: 20px;">Thông tin cá nhân</h2>
							@Html.AntiForgeryToken()
							<div class="profile-info" style="text-align: left; font-size: 1rem;">
								<p><strong>Tên đăng nhập:</strong> <span>@User.Identity.Name</span></p>
								<p><strong>Email:</strong> <span>@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value</span></p>
								<hr style="margin: 20px 0;" />
								<h3 style="font-size: 1.2rem; margin-bottom: 15px;">Đổi mật khẩu</h3>
								<input type="password" placeholder="Mật khẩu cũ" id="old-pass" class="form-control-custom">
								<input type="password" placeholder="Mật khẩu mới" id="new-pass" class="form-control-custom">
								<button class="btn-save-pw" onclick="changePassword()">Cập nhật mật khẩu</button>
							</div>
						</div>
					</div>

				</div>
				<!-- toggle switch for light and dark theme -->
				<div class="mobile-position">
					<nav class="navigation">
						<div class="theme-switch-wrapper">
							<label class="theme-switch" for="checkbox">
								<input type="checkbox" id="checkbox">
								<div class="mode-container">
									<i class="gg-sun"></i>
									<i class="gg-moon"></i>
								</div>
							</label>
						</div>
					</nav>
				</div>
			</div>
		</nav>
	</header>
	<!--/breadcrumbs -->
	<div class="w3l-breadcrumbs">
		<nav id="breadcrumbs" class="breadcrumbs">
	<div class="container page-wrapper">
		<a class="navbar-brand" asp-controller="Home" asp-action="Index">Home</a> »
		<span class="breadcrumb_last" aria-current="page">Movies</span>
	</div>
		</nav>
	</div>
	<!--/Movies -->
	<!--grids-sec1-->
	<section class="w3l-grids">
		<div class="grids-main py-4">
			<div class="container py-lg-4">

				<div class="headerhny-title">
						<h3 class="hny-title">Now Playing</h3>
				</div>
				<div class="owl-four owl-carousel owl-theme">
					@foreach (var movie in Model)
					{
						<div class="item vhny-grid">
							<div class="box16">
								<a asp-controller="Home" asp-action="Ticket_Booking" asp-route-id="@movie.MovieId">
									<figure>
										<img class="img-fluid" src="@movie.PosterUrl" alt="@movie.Title">
									</figure>

									<div class="box-content">
										<h3 class="title">@movie.Title</h3>

										<h4>
											<span class="post">
												<span class="fa fa-clock-o"></span>
												@movie.Duration min
											</span>
										</h4>
									</div>

									<span class="fa fa-play video-icon"></span>
								</a>
							</div>
						</div>
					}
				</div>
			</div>
		</div>
	</section>
	<!--grids-sec1-->
	<section class="w3l-grids">
		<div class="grids-main py-5">
			<div class="container py-lg-4">
				<div class="headerhny-title">
					<div class="w3l-title-grids">
						<div class="headerhny-left">
								<h3 class="hny-title">Coming Soon</h3>
						</div>
						<div class="headerhny-right text-lg-right">
							<h4><a class="show-title" asp-controller="Home" asp-action="Movies">Show all</a></h4>
						</div>
					</div>
				</div>
				<div class="w3l-populohny-grids">
				@foreach (var movie in Model)
				{
					<div class="item vhny-grid">
						<div class="box16 mb-0">

							<figure>
								<img class="img-fluid" src="@movie.PosterUrl" alt="@movie.Title">
							</figure>

							<a href="#movieModal_@movie.MovieId" data-toggle="modal">

								<div class="box-content">

									<h3 class="title">@movie.Title</h3>

									<h4>
										<span class="post">
											<span class="fa fa-clock-o"></span>
											@movie.Duration min
										</span>

										<span class="post fa fa-heart text-right"></span>
									</h4>

								</div>

							</a>

							<!-- Modal -->
							<div class="modal fade" id="movieModal_@movie.MovieId" tabindex="-1">

								<div class="modal-dialog">
									<div class="modal-content" id="mymodalcontent">

										<div class="modal-header">

											<h4 class="modal-title">DETAILS</h4>

											<button type="button" class="closebtn" data-dismiss="modal">
												<span>&times;</span>
											</button>

										</div>

										<div class="modal-body">

											<img src="@movie.PosterUrl"
												 class="img-fluid modalimg" />

											<p>
												<h3>Release Date : @(movie.ReleaseDate.HasValue ? movie.ReleaseDate.Value.ToShortDateString() : "N/A")</h3>
												<h3>Genre : @movie.Genre</h3>
											</p>

											<h4>About Movie</h4>

											<p>
												@movie.Description
											</p>

											<h4>Language</h4>

											<p>
												@movie.Language
											</p>

										</div>

										<div class="bookbtn">
											@if (Context.Session.GetString("UserId") == null)
											{
												@* Chuyển hướng thẳng đến trang Sign_In *@
												<a asp-controller="Home" 
												   asp-action="Sign_In" 
												   class="btn btn-success">
													Book
												</a>
											}
											else
											{
												@* Nếu đã đăng nhập: Cho phép đi tiếp *@
												<a asp-controller="Home"
												   asp-action="Ticket_Booking"
												   asp-route-id="@movie.MovieId"
												   class="btn btn-success">
													Book
												</a>
											}
										</div>
									</div>
								</div>
							</div>

						</div>
					</div>
				}

				</div>

			</div>
			<div class="button-center text-center mt-3">
				<a href="#" class="btn view-button">View all <span class="fa fa-angle-double-right ml-2"
						aria-hidden="true"></span></a>
			</div>
		</div>
	</section>

	<section class="w3l-albums py-5" id="projects">
