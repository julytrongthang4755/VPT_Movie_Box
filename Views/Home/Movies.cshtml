                                }

                            </div>
                        </div>


                        <!-- Trend Movies -->
                        <div class="albums-content">
                            <div class="row">

                                @foreach (var movie in Model.Take(9))
                                {
                                    <div class="col-lg-4 new-relise-gd mt-lg-4 mt-0">

                                        <div class="slider-info">

                                            <div class="img-circle">

                                                <a asp-controller="Home"
                                                   asp-action="Ticket_Booking"
                                                   asp-route-id="@movie.MovieId">

                                                    <img src="@movie.PosterUrl"
                                                         class="img-fluid"
                                                         alt="@movie.Title">

                                                    <div class="overlay-icon">
                                                        <span class="fa fa-play video-icon"></span>
                                                    </div>

                                                </a>

                                            </div>

                                            <div class="message">

                                                <p>@movie.Language</p>

                                                <a class="author-book-title">
                                                    @movie.Title
                                                </a>

                                                <h4>
                                                    <span class="post">
                                                        <span class="fa fa-clock-o"></span>
                                                        @movie.Duration min
                                                    </span>

                                                    <span class="post fa fa-heart text-right"></span>
                                                </h4>

                                            </div>

                                        </div>

                                    </div>
                                }

                            </div>
                        </div>

                    </div>

                </div>

            </div>
        </div>
    </div>
</section>

